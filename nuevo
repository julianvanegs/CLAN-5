<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Navbar Toggle</title>
  <style>
    body {
      margin: 0;
      font-family: Arial;
    }

    nav {
      background: #333;
      color: white;
      padding: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .menu {
      display: none;
      flex-direction: column;
      background: #444;
      position: absolute;
      top: 50px;
      right: 0;
      width: 150px;
    }

    .menu.show {
      display: flex;
    }

    .menu a {
      color: white;
      padding: 10px;
      text-decoration: none;
    }

    .btn {
      cursor: pointer;
      font-size: 20px;
    }
  </style>
</head>
<body>

<nav>
  <div>Logo</div>
  <div class="btn" id="btn">☰</div>
</nav>

<div class="menu" id="menu">
  <a href="#">Inicio</a>
  <a href="#">Servicios</a>
  <a href="#">Contacto</a>
</div>

<script>
  const btn = document.getElementById("btn");
  const menu = document.getElementById("menu");

  btn.addEventListener("click", () => {
    menu.classList.toggle("show");
  });
</script>

</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Tabla HTML</title>
    <style>
        table {
            width: 50%;
            border-collapse: collapse;
        }
        th, td {
            border: 1px solid black;
            padding: 8px;
            text-align: center;
        }
        th {
            background-color: #f2f2f2;
        }
    </style>
</head>
<body>

    <h2>Ejemplo de Tabla</h2>

    <table>
        <thead>
            <tr>
                <th>Encabezado 1</th>
                <th>Encabezado 2</th>
                <th>Encabezado 3</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Fila 1, Columna 1</td>
                <td>Fila 1, Columna 2</td>
                <td>Fila 1, Columna 3</td>
            </tr>
            <tr>
                <td>Fila 2, Columna 1</td>
                <td>Fila 2, Columna 2</td>
                <td>Fila 2, Columna 3</td>
            </tr>
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3">Pie de tabla</td>
            </tr>
        </tfoot>
    </table>

</body>
</html>

